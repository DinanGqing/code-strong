classDiagram
    class EnvVars {
        <<interface>>
        +string VITE_API_BASE
        +string VITE_PLATFORM
    }

    class ViteConfig {
        +string root
        +string base
        +buildConfig build
        +serverConfig server
        +string outDir
        +array~Plugin~ plugins
    }

    class webViteConfig {
        +string outDir = "dist/web"
        +string entry = "src/web/index.html"
    }

    class appViteConfig {
        +string outDir = "dist/app"
        +string entry = "src/app/index.html"
    }

    ViteConfig <|-- webViteConfig
    ViteConfig <|-- appViteConfig
    EnvVars ..> webViteConfig : injected by
    EnvVars ..> appViteConfig : injected by

    class srcLayout {
        <<directory>>
    }

    class shared {
        <<directory>>
        +api/
        +contexts/
        +hooks/
        +data/
        +components/
        +assets/
    }

    class web {
        <<directory>>
        +index.html
        +main.jsx
        +App.jsx
        +components/
        +pages/
    }

    class app {
        <<directory>>
        +index.html
        +main.jsx
        +App.jsx
        +components/
        +pages/
    }

    srcLayout --> shared : contains
    srcLayout --> web : contains
    srcLayout --> app : contains
    web ..> shared : imports from
    app ..> shared : imports from
